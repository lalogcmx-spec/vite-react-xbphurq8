# =============================================================================
# FacturaBot MX — Variables de Entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA comitas el archivo .env al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# SERVIDOR
# -----------------------------------------------------------------------------
APP_PORT=3000
NODE_ENV=production

# -----------------------------------------------------------------------------
# SUPABASE
# Obtén estos valores en: https://supabase.com/dashboard → Settings → API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXX

# -----------------------------------------------------------------------------
# GEMINI
# Obtén tu API key gratis en: https://aistudio.google.com/apikey
# Modelo usado: gemini-1.5-flash (capa gratuita, OCR + fallback de Vision
# en los drivers de automatización). Usado en vez de OpenAI por costo.
# -----------------------------------------------------------------------------
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# REDIS (BullMQ)
# Para desarrollo local: redis://localhost:6379
# Para producción: usa Redis Cloud, Upstash, o Railway Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# Alternativa con usuario/contraseña:
# REDIS_URL=redis://usuario:contraseña@host:6379

# -----------------------------------------------------------------------------
# META WHATSAPP CLOUD API
# Configuración en: https://developers.facebook.com → Tu App → WhatsApp
# -----------------------------------------------------------------------------

# Token de verificación que defines tú mismo para el webhook (cualquier string seguro)
META_VERIFY_TOKEN=mi_token_secreto_webhook_2024

# Token de acceso permanente del sistema (System User Access Token)
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID del número de teléfono de WhatsApp Business
# Lo encuentras en: Meta Developer Console → WhatsApp → API Setup
META_PHONE_NUMBER_ID=123456789012345

# ID de la cuenta de WhatsApp Business (opcional, para webhooks)
META_WABA_ID=987654321098765

# Número de WhatsApp del administrador/operador, en formato E.164 sin "+".
# El driver de OXXO (y cualquier scraper con fallback de visión) envía una
# alerta aquí cuando agota selectores + GPT Vision y no logra facturar un
# ticket sin intervención humana. Si se deja vacío, el fallo solo queda
# registrado en logs.
ADMIN_WHATSAPP_NUMBER=5215512345678

# -----------------------------------------------------------------------------
# SMTP — Envío de correos con facturas adjuntas
# Ejemplos: Gmail, SendGrid, Mailgun, SES, Brevo
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=facturabot@tudominio.com
SMTP_PASS=tu_app_password_gmail
SMTP_FROM=FacturaBot MX <facturabot@tudominio.com>

# Con SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.XXXXXXXXXXXXXXXXXXXXXXXX

# Con Brevo (Sendinblue):
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=tu@email.com
# SMTP_PASS=xsmtpsib-XXXXXXXXXXXX

# -----------------------------------------------------------------------------
# PLAYWRIGHT (opcional)
# Si usas una instalación custom de Chromium
# -----------------------------------------------------------------------------
# CHROMIUM_PATH=/usr/bin/chromium-browser

# -----------------------------------------------------------------------------
# MERCHANT INTELLIGENCE ENGINE — drivers genéricos por GPT Vision
# Walmart, Starbucks y Zara no tienen selectores ni portal verificados
# todavía. El driver genérico (server/src/drivers/genericVisionDriver.ts)
# se niega a correr hasta que configures la URL real de su portal de
# autofacturación aquí. No se adivinan URLs.
# -----------------------------------------------------------------------------
# MERCHANT_PORTAL_WALMART=https://facturacion.walmart.com.mx/
# MERCHANT_PORTAL_STARBUCKS=https://www.starbucksmexico.com.mx/facturacion
# MERCHANT_PORTAL_ZARA=https://www.facturacionzara.com.mx/

# -----------------------------------------------------------------------------
# SUPABASE STORAGE BUCKETS (deben existir en tu proyecto Supabase)
# Crea manualmente en: Supabase → Storage → New Bucket
# - tickets    (público, para imágenes de tickets recibidos)
# - facturas   (privado o público con signed URLs, para XML y PDF)
# -----------------------------------------------------------------------------

