# =============================================================================
# FacturaBot MX — .env de trabajo
# Completa SUPABASE_URL, SUPABASE_SERVICE_KEY, OPENAI_API_KEY,
# META_ACCESS_TOKEN, META_PHONE_NUMBER_ID y las credenciales SMTP.
# =============================================================================

APP_PORT=3000
NODE_ENV=development

# --- SUPABASE (reemplaza con tus valores reales) ---
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.TU_SERVICE_KEY

# --- OPENAI ---
OPENAI_API_KEY=sk-proj-TU_API_KEY

# --- REDIS ---
REDIS_URL=redis://127.0.0.1:6379

# --- META WHATSAPP CLOUD API ---
META_VERIFY_TOKEN=facturabot_webhook_2024
META_ACCESS_TOKEN=EAA_TU_ACCESS_TOKEN
META_PHONE_NUMBER_ID=TU_PHONE_NUMBER_ID

# --- SMTP (ejemplo Gmail con App Password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
SMTP_FROM=FacturaBot MX <tu@gmail.com>

# --- PLAYWRIGHT ---
CHROMIUM_PATH=/opt/pw-browsers/chromium-1194/chrome-linux/chrome
PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
