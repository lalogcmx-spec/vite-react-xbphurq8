{
  "name": "facturabot-mx-server",
  "version": "1.0.0",
  "description": "FacturaBot MX — Backend de facturación automática por WhatsApp",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "typecheck": "tsc --noEmit",
    "setup": "./bootstrap.sh",
    "pm2:start": "pm2 startOrReload ecosystem.config.cjs --update-env",
    "pm2:stop": "pm2 stop facturabot-mx",
    "pm2:restart": "pm2 restart facturabot-mx",
    "pm2:logs": "pm2 logs facturabot-mx",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.5",
    "axios": "^1.7.2",
    "bullmq": "^5.7.15",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "nodemailer": "^6.9.13",
    "openai": "^4.52.1",
    "playwright": "^1.44.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/nodemailer": "^6.4.15",
    "pm2": "^7.0.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
